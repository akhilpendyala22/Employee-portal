# Copy to .env and fill in. Never commit .env to source control.

# Required in production. Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# 'development' or 'production'
FLASK_ENV=development
FLASK_CONFIG=development

# Optional — defaults to SQLite under instance/portal.db
# DATABASE_URL=postgresql://user:pass@localhost/portal
